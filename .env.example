ENVIRONMENT=development
DEBUG=false
DOCS_ENABLED=true
DATABASE_URL=postgresql+asyncpg://stopcard:stopcard@postgres:5432/stopcard

TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=3600

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=stopcard
MINIO_SECRET_KEY=replace-with-a-long-secret
MINIO_SECURE=false
MINIO_BUCKET=stopcard
MINIO_REGION=us-east-1
# Public CDN/base URL is optional. Without it the API returns a presigned MinIO URL.
MINIO_PUBLIC_URL=
# Host visible to the client; signing itself does not perform a network request.
MINIO_PRESIGN_ENDPOINT=localhost:9000
MINIO_PRESIGN_SECURE=false
PHOTO_MAX_BYTES=10485760
PHOTO_URL_EXPIRES_SECONDS=3600

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_MINUTES=60
CORS_ORIGINS=["https://stop-card.kz"]
TRUSTED_HOSTS=["localhost","127.0.0.1","testserver"]
