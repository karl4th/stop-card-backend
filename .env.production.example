ENVIRONMENT=production
DEBUG=false
DOCS_ENABLED=true

# Generate unique values before deployment. Do not commit .env.production.
POSTGRES_DB=stopcard
POSTGRES_USER=stopcard
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgresql+asyncpg://stopcard:replace-with-a-long-random-postgres-password@postgres:5432/stopcard

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_AUTH_MAX_AGE_SECONDS=3600

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-a-long-random-minio-secret
MINIO_SECURE=false
MINIO_BUCKET=stopcard
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=
# Nginx proxies signed photo requests from this public endpoint to MinIO.
MINIO_PRESIGN_ENDPOINT=api.stop-card.kz
MINIO_PRESIGN_SECURE=true
PHOTO_MAX_BYTES=10485760
PHOTO_URL_EXPIRES_SECONDS=3600

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_MINUTES=60
CORS_ORIGINS=["https://stop-card.kz","https://www.stop-card.kz"]
TRUSTED_HOSTS=["api.stop-card.kz","api","127.0.0.1","localhost"]

DOMAIN=api.stop-card.kz
LETSENCRYPT_EMAIL=replace-with-your-email
ADMIN_USERNAME=admin
